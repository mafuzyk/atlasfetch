    for line in distro_name.splitlines():
        if line.startswith("PRETTY_NAME="):
            distro_name = line.split("=", 1)[1].strip('"')
            break
    else:
        distro_name = distro_id or "Linux"

    print()
    print(style("  atlasfetch setup", bold=True, fg="#FF9A98"))
    print(f"  Distro detectada: {distro_name}")
    print()

    # ── Escolher paleta ──
    all_presets = _flatten_presets()
    print(style("  ── Paleta de cores ──", fg="#9D85FF"))
    print()
    print("  \033[1mBandeiras LGBTQ+\033[0m")
    for i, (name, _) in enumerate(PRESETS["flags"].items(), 1):
        print(f"   {i:2d}) {name}")
    offset = len(PRESETS["flags"])
    print("  \033[1mTemas\033[0m")
    for i, (name, _) in enumerate(PRESETS["themes"].items(), offset + 1):
        print(f"  {i:2d}) {name}")
    print(f"   c)  Criar paleta customizada")
    print(f"   k)  Manter paleta atual")
    print()

    choice = input("  Escolha (1-{}, c, k): ".format(len(all_presets))).strip().lower()
    print()

    colors = None
    if choice == "c":
        raw = input("  Digite cores hex separadas por espaço (ex: #ff0000 #00ff00 #0000ff): ").strip()
        parts = raw.split()
        valid = [p for p in parts if re.match(r'^#[0-9a-fA-F]{6}$', p)]
        if len(valid) >= 2:
            colors = valid
            custom_name = "_".join(valid[:3])
            if "custom_palettes" not in cfg:
                cfg["custom_palettes"] = {}
            cfg["custom_palettes"][custom_name] = colors
            print(style(f"  ✓ Paleta customizada salva", fg="#50fa7b"))
        else:
            print(style("  ✗ Pelo menos 2 cores hex válidas necessárias", fg="#ff5555"))
            colors = DEFAULT_CFG["logo"]["colors"]
    elif choice == "k":
        colors = cfg.get("logo", {}).get("colors", DEFAULT_CFG["logo"]["colors"])
        print(style("  ✓ Paleta atual mantida", fg="#50fa7b"))
    else:
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(all_presets):
                name, colors = all_presets[idx]
                print(style(f"  ✓ Paleta \"{name}\" selecionada", fg="#50fa7b"))
            else:
                raise ValueError
        except (ValueError, IndexError):
            print(style("  ✗ Opção inválida, usando paleta padrão", fg="#ff5555"))
            colors = DEFAULT_CFG["logo"]["colors"]

    # ── Escolher ASCII ──
    print()
    print(style("  ── ASCII Art ──", fg="#9D85FF"))
    print()
    logo_key = OS_LOGO_MAP.get(distro_id, "")
    logo_choices = sorted(DISTRO_LOGOS.keys())
    distro_logo_name = logo_key if logo_key in DISTRO_LOGOS else "arch"

    print(f"   a)  Usar ASCII da distro ({distro_logo_name}) [padrão]")
    print(f"   b)  Escolher outra ASCII")
    print(f"   k)  Manter ASCII atual")
    print()

    logo_choice = input(f"  Escolha (a, b, k): ").strip().lower()
    print()

    if logo_choice == "b":
        print("  ASCIIs disponíveis:")
        for i, lk in enumerate(logo_choices, 1):
            print(f"  {i:2d}) {lk}")
        print()
        lc = input(f"  Escolha (1-{len(logo_choices)}): ").strip()
        try:
            lidx = int(lc) - 1
            if 0 <= lidx < len(logo_choices):
                logo_key = logo_choices[lidx]
            else:
                raise ValueError
        except ValueError:
            logo_key = distro_logo_name
    elif logo_choice == "k":
        logo_key = None
    else:
        logo_key = distro_logo_name

    # ── Aplicar ──
    cfg["logo"]["colors"] = colors
    cfg["setup_done"] = True
    _save_config(cfg)

    if logo_key and logo_key in DISTRO_LOGOS:
        logo_path = os.path.expanduser(cfg["logo"]["path"])
        os.makedirs(os.path.dirname(logo_path), exist_ok=True)
        with open(logo_path, "w") as f:
            f.write(DISTRO_LOGOS[logo_key])
        print(style(f"  ✓ ASCII \"{logo_key}\" salva em {logo_path}", fg="#50fa7b"))

    print()
    print(style("  ✓ Configuração concluída! Execute atlasfetch para ver o resultado.", fg="#50fa7b", bold=True))
    print()

def _show_help():
    print("atlasfetch — fetch customizável com ASCII e powerline")
    print()
    print("Uso:  atlasfetch [opções]")
    print()
    print("Opções:")
    print("  -h, --help            Mostra esta ajuda")
    print("  -v, --version         Mostra a versão")
    print("  -i, --setup           Assistente de configuração interativo")
    print("  --preset <nome>       Aplica uma paleta e sai")
    print("  --list-presets        Lista paletas disponíveis")
    print()
    print("Config:  ~/.config/atlasfetch/config.json")
    print("Logo:    ~/.config/atlasfetch/logo.txt")
    print()
    print("Campos disponíveis para o display:")
    for name in sorted(PROVIDER_DOCS.keys()):
        print(f"  {name:12s} — {PROVIDER_DOCS[name]}")

def main():
    args = sys.argv[1:]

    if "-h" in args or "--help" in args:
        _show_help()
        return

    if "-v" in args or "--version" in args:
        print("atlasfetch 2.0")
        return

    if "--list-presets" in args:
        _list_presets_cmd()
        return

    if "-i" in args or "--setup" in args:
        _run_setup()
        return

    for i, a in enumerate(args):
        if a == "--preset" and i + 1 < len(args):
            name = args[i + 1]
            colors = _apply_preset(name)
            if colors is None:
                cfg_tmp = load_config()
                custom = cfg_tmp.get("custom_palettes", {})
                if name in custom:
                    colors = custom[name]
            if colors:
                write_defaults()
                cfg_tmp = load_config()
                cfg_tmp["logo"]["colors"] = list(colors)
                cfg_tmp["setup_done"] = True
                _save_config(cfg_tmp)
                print(f"Paleta \"{name}\" aplicada.")
            else:
                print(f"Paleta \"{name}\" não encontrada. Use --list-presets.")
            return

    write_defaults()
    global cfg
    cfg = load_config()

    if cfg.get("setup_done") is not True:
        _run_setup()
        cfg = load_config()

    logo_text = load_logo(cfg)
    logo_lines = logo_text.strip("\n").split("\n") if logo_text else []
    logo_colors = cfg.get("logo", {}).get("colors", DEFAULT_CFG["logo"]["colors"])

    info = _collect_info(cfg)
    render(info, logo_lines, logo_colors, cfg)


