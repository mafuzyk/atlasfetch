def build(icon, label, value, fg_color, avail_w, panel_cfg):
    seg = f" {icon} {label} "
    sep = "\ue0b0"
    val_text = f" {value} "

    seg_vis = vlen(seg)
    val_vis = vlen(val_text)
    sep_color = panel_cfg.get("sep_color", "#9D85FF")
    val_color = panel_cfg.get("val_color", "#f5dce3")

    if seg_vis + 1 + val_vis > avail_w:
        need = seg_vis + 1 + 3
        if need > avail_w:
            if seg_vis > avail_w - 3:
                seg = f" {icon} "
            val_text = ""
        else:
            r = avail_w - seg_vis - 2
            if r < 1:
                val_text = ""
            else:
                visible = value[:max(0, r - 2)]
                if len(visible) < len(value):
                    visible = visible[:-1] + "\u2026"
                val_text = " " + visible + " "

    out = style(seg, fg=fg_color)
    out += style(sep, fg=sep_color)
    if val_text.strip():
        out += style(val_text, fg=val_color)
    return out, vlen(out)


def cascade_offset(i, total, max_shift):
    if total <= 1:
        return 0
    mid = (total - 1) / 2
    return round(abs((i / mid) - 1) * max_shift) if mid > 0 else 0


def center_line(line, width):
    s = line.rstrip()
    if not s:
        return " " * width
    pad = width - len(s)
    if pad <= 0:
        return s
    return " " * (pad // 2) + s + " " * (pad - pad // 2)


def render(info, logo_lines, logo_colors, cfg):
    tw = shutil.get_terminal_size().columns

    pan = cfg["panel"]
    GAP = pan.get("gap", 2)
    LEFT_PAD = pan.get("left_pad", 3)
    RIGHT_PAD = pan.get("right_pad", 3)
    MAX_SHIFT = pan.get("max_shift", 2)

    # Esconde ASCII se o terminal for estreito demais pros painéis
    if logo_lines:
        lw_test = max(len(l) for l in logo_lines)
        origin_test = (tw - lw_test) // 2
        if origin_test - LEFT_PAD - GAP < 8 or tw - origin_test - lw_test - GAP - RIGHT_PAD - MAX_SHIFT < 8:
            logo_lines = []

    lh = len(logo_lines)
    lw = max(len(l) for l in logo_lines) if logo_lines else 0

    left_defs = cfg.get("display", {}).get("left", [])
    right_defs = cfg.get("display", {}).get("right", [])
    n = max(len(left_defs), len(right_defs))

    # ── título ──
    fmt = cfg.get("title", {}).get("format", "{user}@{host}")
    title_color = cfg.get("title", {}).get("color") or logo_colors[1] if logo_colors else "#ffffff"
    title_text = fmt.format(**info)
    print()
    print(style(f"  {title_text}", fg=title_color, bold=True))

    # ── separador ──
    sep_cfg = cfg.get("separator", {})
    sep_char = sep_cfg.get("char", "\u2500")
    sep_color = sep_cfg.get("color", "#9D85FF")
    sep_len = min(tw - 4, sep_cfg.get("length", 48))
    print(style(f"  {sep_char * sep_len}", fg=sep_color))

    # ── corpo ──
    if lh == 0:
        # sem ASCII → só painéis
        n_iter = n
        logo_origin = 0
        lw = 0
    else:
        n_iter = lh
        logo_origin = (tw - lw) // 2 if lw < tw else 0

    start_row = max(0, (lh - n) // 2)

    for i in range(n_iter):
        in_range = start_row <= i < start_row + n if lh else True

        if in_range:
            idx = i - start_row if lh else i
            shift = cascade_offset(idx, n, MAX_SHIFT)

            l_def = left_defs[idx] if idx < len(left_defs) else None
            r_def = right_defs[idx] if idx < len(right_defs) else None

            l_val = info.get(l_def[0], "—") if l_def else ""
            r_val = info.get(r_def[0], "—") if r_def else ""

            bg_left = logo_colors[idx % len(logo_colors)]
            bg_right = logo_colors[(idx + 3) % len(logo_colors)]
        else:
            shift = cascade_offset(i - start_row + n // 2, n, MAX_SHIFT)
            l_val = r_val = None
            l_def = r_def = None

        # coloriza a logo
        colored_logo = ""
        if lh:
            for ch in center_line(logo_lines[i], lw):
                if ch != " ":
                    colored_logo += style(ch, logo_colors[i % len(logo_colors)])
                else:
                    colored_logo += " "

        if in_range:
            l_start = LEFT_PAD + shift
            l_avail = max(4, logo_origin - l_start - GAP)
            r_avail = max(4, tw - logo_origin - lw - GAP - RIGHT_PAD - MAX_SHIFT)

            l_text = ""
            if l_def:
                l_text, l_vis = build(l_def[1], l_def[2], l_val, bg_left, l_avail, pan)
            else:
                l_vis = 0

            r_text = ""
            if r_def:
                r_text, r_vis = build(r_def[1], r_def[2], r_val, bg_right, r_avail, pan)
            else:
                r_vis = 0

            l_pad = l_avail - l_vis
            l_blk = " " * l_pad if l_pad > 0 else ""
            row = " " * l_start + l_text + l_blk + " " * GAP + colored_logo
            if r_text.strip():
                r_target = tw - RIGHT_PAD - shift
                gap = r_target - r_vis - vlen(row)
                row += " " * max(0, gap) + r_text
        else:
            row = " " * logo_origin + colored_logo

        # garante que a linha tem exatamente tw colunas
        rv = vlen(row)
        if rv > tw:
            while vlen(row) > tw and row:
                row = row[:-1]
        elif rv < tw:
            row += " " * (tw - rv)

        print(row)

    print()

