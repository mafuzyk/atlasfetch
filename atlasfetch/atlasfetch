def _read_first(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except OSError:
        return ""

def _detect_distro():
    text = _read_first("/etc/os-release")
    for line in text.splitlines():
        if line.startswith("ID="):
            return line.split("=", 1)[1].strip('"')
    return ""

def _count_packages():
    count = 0
    os_id = _detect_distro()

    try:
        count += len(os.listdir("/var/lib/pacman/local/"))
    except OSError:
        pass

    if os_id in ("debian", "ubuntu", "linuxmint", "pop", "elementary", "raspbian", "kali", "deepin"):
        try:
            with open("/var/lib/dpkg/status") as f:
                count += f.read().count("Status: install ok installed")
        except OSError:
            pass

    if os_id in ("void",):
        try:
            db = "/var/db/xbps"
            if os.path.isdir(db):
                count += len([e for e in os.listdir(db) if e.endswith(".plist") or not e.startswith(".")])
        except OSError:
            pass

    if os_id in ("gentoo",):
        try:
            for cat in os.listdir("/var/db/pkg/"):
                cp = os.path.join("/var/db/pkg", cat)
                if os.path.isdir(cp):
                    count += len(os.listdir(cp))
        except OSError:
            pass

    if os_id in ("slackware",):
        try:
            count += len(os.listdir("/var/log/packages/"))
        except OSError:
            pass

    if os_id in ("alpine",):
        try:
            out = subprocess.run(["apk", "info"], capture_output=True, text=True, timeout=5)
            if out.returncode == 0:
                count += len([l for l in out.stdout.splitlines() if l.strip()])
        except Exception:
            pass

    if os_id in ("fedora", "rhel", "centos", "rocky", "almalinux", "opensuse", "suse", "fedora-asahi-remix"):
        try:
            out = subprocess.run(["rpm", "-qa", "--queryformat", "%{NAME}\n"],
                                 capture_output=True, text=True, timeout=10)
            if out.returncode == 0:
                count += len([l for l in out.stdout.splitlines() if l.strip()])
        except Exception:
            pass

    if os_id in ("nixos",):
        try:
            out = subprocess.run(["nix-env", "-q"], capture_output=True, text=True, timeout=10)
            if out.returncode == 0:
                count += len([l for l in out.stdout.splitlines() if l.strip()])
        except Exception:
            pass

    for fp in ("/var/lib/flatpak", os.path.expanduser("~/.local/share/flatpak")):
        app_dir = os.path.join(fp, "app")
        try:
            count += len([d for d in os.listdir(app_dir) if os.path.isdir(os.path.join(app_dir, d))])
        except OSError:
            pass

    try:
        snap_dir = "/var/lib/snapd/snaps"
        if os.path.isdir(snap_dir):
            count += len([e for e in os.listdir(snap_dir) if e.endswith(".snap")])
    except OSError:
        pass

    return count or "—"


def _collect_info(cfg):
    """Coleta todos os campos definidos no display + título."""
    needed = set()
    needed.add("user")
    needed.add("host")
    for side in ("left", "right"):
        for entry in cfg.get("display", {}).get(side, []):
            if entry:
                needed.add(entry[0])
    # título também pode referenciar campos via format
    fmt = cfg.get("title", {}).get("format", "{user}@{host}")
    for m in re.finditer(r"\{(\w+)\}", fmt):
        needed.add(m.group(1))

    info = {}

    def need(name):
        return name in needed

    # ── user / host ──
    if need("user"):
        info["user"] = os.environ.get("USER") or os.environ.get("USERNAME") or "user"
    if need("host"):
        info["host"] = _read_first("/proc/sys/kernel/hostname") or "localhost"

    # ── os ──
    if need("os"):
        os_name = "—"
        text = _read_first("/etc/os-release")
        for line in text.splitlines():
            if "=" in line:
                k, v = line.split("=", 1)
                v = v.strip('"')
                if k == "PRETTY_NAME":
                    os_name = v
                    break
                elif k == "NAME" and os_name == "—":
                    os_name = v
        info["os"] = os_name

    # ── kernel ──
    if need("kernel"):
        info["kernel"] = os.uname().release

    # ── uptime ──
    if need("uptime"):
        try:
            with open("/proc/uptime") as f:
                sec = float(f.read().split()[0])
            h, m = int(sec // 3600), int((sec % 3600) // 60)
            info["uptime"] = f"{h}h {m}m"
        except Exception:
            info["uptime"] = "—"

    # ── packages (multi-distro) ──
    if need("packages"):
        info["packages"] = _count_packages()

    # ── shell ──
    if need("shell"):
        info["shell"] = os.path.basename(os.environ.get("SHELL", "fish"))

    # ── terminal ──
    if need("terminal"):
        term = os.environ.get("TERMINAL") or os.environ.get("TERM", "")
        term = term.lower()
        if not term or term in ("linux", "vt100"):
            term = "—"
        else:
            term = term.replace("xterm-", "")
        info["terminal"] = term

    # ── cpu ──
    if need("cpu"):
        cpu = "—"
        text = _read_first("/proc/cpuinfo")
        for line in text.splitlines():
            if "model name" in line:
                cpu = line.split(":", 1)[1].strip()
                break
        cpu = re.sub(r'\s*\([^)]*\)|\s*®|\s*™|\s*(Quad|Dual|Six|Eight|Twelve|Sixteen)\s*[- ]?Core|\s*Core\b', '', cpu)
        cpu = re.sub(r'\s+with\s+.*', '', cpu)
        cpu = " ".join(cpu.split())
        info["cpu"] = cpu

    # ── gpu (via /sys/class/drm + pci.ids) ──
    if need("gpu"):
        info["gpu"] = _get_gpu()

    # ── memory ──
    if need("memory"):
        try:
            mem = {}
            for line in _read_first("/proc/meminfo").splitlines():
                if ":" in line:
                    k, v = line.split(":", 1)
                    mem[k.strip()] = v.strip()
            total_kb = int(mem.get("MemTotal", "0").replace(" kB", ""))
            avail_kb = int(mem.get("MemAvailable", "0").replace(" kB", ""))
            used_kb = total_kb - avail_kb
            info["memory"] = f"{used_kb/1024**2:.1f}/{total_kb/1024**2:.1f}G"
        except Exception:
            info["memory"] = "—"

    # ── disk ──
    if need("disk"):
        try:
            u = shutil.disk_usage("/")
            info["disk"] = f"{u.used // 2**30}/{u.total // 2**30}G"
        except Exception:
            info["disk"] = "—"

    # ── wm ──
    if need("wm"):
        wm = os.environ.get("XDG_CURRENT_DESKTOP", "")
        if not wm:
            out = _try_hyprctl()
            if out:
                wm = "Hyprland"
        info["wm"] = wm or "—"

    # ── load ──
    if need("load"):
        try:
            with open("/proc/loadavg") as f:
                parts = f.read().split()
            info["load"] = " ".join(parts[:3])
        except Exception:
            info["load"] = "—"

    # ── processes ──
    if need("processes"):
        try:
            procs = [d for d in os.listdir("/proc") if d.isdigit()]
            info["processes"] = str(len(procs))
        except Exception:
            info["processes"] = "—"

    # ── local_ip ──
    if need("local_ip"):
        ip = "—"
        try:
            text = _read_first("/proc/net/route")
            iface = ""
            for line in text.splitlines()[1:]:
                parts = line.split()
                if parts and parts[1] != "00000000":
                    iface = parts[0]
                    break
            if iface:
                with open(f"/sys/class/net/{iface}/address") as f:
                    mac = f.read().strip()
                ip = _get_ip_from_iface(iface)
            info["local_ip"] = ip or "—"
        except Exception:
            info["local_ip"] = "—"

    # ── resolution (fork opcional — hyprctl) ──
    if need("resolution"):
        info["resolution"] = _try_resolution()

    # ── de ──
    if need("de"):
        info["de"] = os.environ.get("XDG_CURRENT_DESKTOP") or "—"

    # ── font ──
    if need("font"):
        info["font"] = _try_font()

    return info


def _try_hyprctl():
    try:
        import subprocess
        return subprocess.run(["hyprctl", "instances"],
                              capture_output=True, text=True, timeout=3).stdout.strip()
    except Exception:
        return ""

def _try_resolution():
    try:
        import subprocess
        for cmd in (
            ["hyprctl", "monitors"],
            ["wlr-randr"],
            ["xrandr"]
        ):
            try:
                out = subprocess.run(cmd, capture_output=True, text=True, timeout=3).stdout
                if "hyprctl" in " ".join(cmd):
                    m = re.search(r"(\d+x\d+)", out)
                elif "wlr-randr" in " ".join(cmd):
                    m = re.search(r"(\d+x\d+)", out)
                else:
                    m = re.search(r"\*.*?(\d+x\d+)", out)
                if m:
                    return m.group(1)
            except Exception:
                continue
    except Exception:
        pass
    return "—"

def _try_font():
    try:
        import subprocess
        return subprocess.run(
            ["fc-match", "-f", "%{family[0]}", "sans"],
            capture_output=True, text=True, timeout=3
        ).stdout.strip()
    except Exception:
        return "—"

def _get_ip_from_iface(iface):
    try:
        import socket, struct, fcntl
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        return socket.inet_ntoa(
            fcntl.ioctl(s.fileno(), 0xc0206921, struct.pack("256s", iface[:15].encode()))[20:24]
        )
    except Exception:
        return "—"


# ── GPU Provider (zero forks — /sys/class/drm + pci.ids) ──

_VENDOR_NAMES = {
    "0x1002": "AMD", "0x1022": "AMD",
    "0x10de": "NVIDIA",
    "0x8086": "Intel",
    "0x1ae0": "Google",
}

def _get_gpu():
    gpu = "—"
    dev_paths = []
    try:
        for entry in sorted(os.listdir("/sys/class/drm/")):
            if entry.startswith("card") and "-" not in entry:
                p = f"/sys/class/drm/{entry}/device"
                if os.path.exists(f"{p}/vendor"):
                    dev_paths.append(p)
    except OSError:
        return gpu

    for p in dev_paths:
        vendor_id = _read_first(f"{p}/vendor")
        device_id = _read_first(f"{p}/device")
        name = _lookup_pci(vendor_id, device_id)
        if name:
            gpu = name
        else:
            gpu = _VENDOR_NAMES.get(vendor_id, vendor_id)
    return gpu

_PCI_CACHE = None

def _load_pci_ids():
    global _PCI_CACHE
    if _PCI_CACHE is not None:
        return _PCI_CACHE
    _PCI_CACHE = {}
    for path in ("/usr/share/hwdata/pci.ids", "/usr/share/misc/pci.ids",
                 "/usr/share/pci.ids"):
        if not os.path.exists(path):
            continue
        try:
            vendors = {}
            cur_vendor = ""
            with open(path, encoding="latin-1", errors="replace") as f:
                for line in f:
                    if line.startswith("#") or line.strip() == "":
                        continue
                    if not line.startswith("\t"):
                        parts = line.split(None, 1)
                        if len(parts) >= 2:
                            cur_vendor = parts[0].lower()
                            vendors[cur_vendor] = parts[1].strip()
                    elif cur_vendor:
                        parts = line.strip().split(None, 1)
                        if len(parts) >= 2:
                            did = parts[0].lower()
                            key = (cur_vendor, did)
                            _PCI_CACHE[key] = f"{vendors[cur_vendor]} {parts[1].strip()}"
        except Exception:
            continue
    return _PCI_CACHE

def _lookup_pci(vendor_id, device_id):
    db = _load_pci_ids()
    if not db:
        return None
    key = (vendor_id.lower().replace("0x", ""), device_id.lower().replace("0x", ""))
    name = db.get(key, "")
    if not name:
        return None
    name = name.replace("Advanced Micro Devices, Inc. [AMD/ATI] ", "")
    name = name.replace("[AMD/ATI] ", "")
    name = name.replace("NVIDIA Corporation ", "")
    name = name.replace("Intel Corporation ", "")
    name = re.sub(r"\s*\(rev\s*\d+\)", "", name)
    m = re.search(r"\[(.+?)\]", name)
    if m:
        inner = m.group(1)
        if not inner.startswith(("0x", "10", "VGA")):
            name = inner
    name = name.replace("Radeon Vega Series / Radeon Vega Mobile Series", "Radeon Vega 8 Graphics")
    name = re.sub(r'\[[0-9a-fA-F]{4}:[0-9a-fA-F]{4,8}\]', '', name)
    name = " ".join(name.split())
    return name

